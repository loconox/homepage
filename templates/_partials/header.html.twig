{% set firstname = content.profile.name|split(' ')|first|lower %}
<header class="fixed top-0 left-0 right-0 z-50 bg-gray-900/90 backdrop-blur-sm border-b border-gray-800">
    <div class="max-w-5xl mx-auto px-6 h-14 flex items-center justify-between">
        <a href="#hero" class="text-cyan-400 font-semibold hover:text-cyan-300 transition-colors text-sm">
            ~/{{ firstname }}
        </a>
        <nav>
            <ul class="flex items-center gap-6 text-sm text-gray-500">
                <li><a href="#services" class="hover:text-cyan-400 transition-colors">#services</a></li>
                <li><a href="#experiences" class="hover:text-cyan-400 transition-colors">#{{ 'nav.experiences'|trans }}</a></li>
                <li><a href="#skills" class="hover:text-cyan-400 transition-colors">#{{ 'nav.skills'|trans }}</a></li>
                <li>
                    <a href="{{ content.profile.cv_url }}"
                       target="_blank"
                       rel="noopener noreferrer"
                       class="hover:text-cyan-400 transition-colors">
                        cv.pdf
                    </a>
                </li>
                <li>
                    <a href="#contact"
                       class="px-3 py-1.5 border border-cyan-400/40 text-cyan-400 text-xs hover:bg-cyan-400/10 hover:border-cyan-400 transition-all">
                        contact
                    </a>
                </li>
                <li class="flex items-center gap-1.5 text-xs">
                    <a href="{{ path('home', {_locale: 'fr'}) }}"
                       class="{{ app.request.locale == 'fr' ? 'text-cyan-400' : 'hover:text-cyan-400' }} transition-colors">FR</a>
                    <span class="text-gray-700 select-none">/</span>
                    <a href="{{ path('home', {_locale: 'en'}) }}"
                       class="{{ app.request.locale == 'en' ? 'text-cyan-400' : 'hover:text-cyan-400' }} transition-colors">EN</a>
                </li>
            </ul>
        </nav>
    </div>
</header>
