{% set quote = content.profile.quote %}
{% if quote %}
    <section class="py-20 border-t border-gray-800">
        <div class="max-w-5xl mx-auto px-6">
            <figure class="max-w-3xl">
                <span class="text-cyan-400 text-2xl font-bold leading-none select-none">"</span>
                <blockquote class="mt-2 text-lg sm:text-xl text-gray-300 leading-relaxed italic">
                    {{ quote.text }}
                </blockquote>
                {% if quote.author %}
                    <figcaption class="mt-4 text-xs text-gray-500">
                        <span class="text-cyan-400">—</span> {{ quote.author }}
                    </figcaption>
                {% endif %}
            </figure>
        </div>
    </section>
{% endif %}
