---
import experiences from '../data/experiences.json';
---

<section id="experiences" class="py-24 border-t border-gray-800">
    <div class="max-w-5xl mx-auto px-6">
        <div class="mb-12">
            <h2 class="text-lg font-bold text-gray-100 mb-3">
                <span class="text-cyan-400">// </span>Expériences
            </h2>
            <div class="h-px bg-gray-800"></div>
        </div>

        <div class="space-y-0">
            {experiences.map((exp, i) => (
                    <div class="grid md:grid-cols-[200px_1fr] gap-4 md:gap-8 py-8 border-b border-gray-800/50 last:border-0 group">
                        <div class="md:pt-0.5">
                            <p class="text-xs text-gray-600 mb-1 group-hover:text-cyan-400/60 transition-colors">
                                ./{String(i + 1).padStart(2, '0')}
                            </p>
                            <p class="text-xs text-gray-500 leading-relaxed">
                                {exp.start}<br class="hidden md:block"/> — {exp.end}
                            </p>
                        </div>
                        <div>
                            <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1 mb-2">
                                <h3 class="font-semibold text-gray-100 text-sm">{exp.role}</h3>
                                <span class="text-cyan-400 text-xs">{exp.company}</span>
                                {exp.companyType && (
                                        <span class="px-1.5 py-0.5 text-[10px] uppercase tracking-wider border border-gray-700 text-gray-500">
                  {exp.companyType}
                </span>
                                )}
                            </div>
                            <ul class="space-y-1 mb-3">
                                {exp.highlights.map((item) => (
                                        <li class="flex gap-2 text-xs text-gray-500 leading-relaxed">
                                            <span class="text-cyan-400/60 select-none">▸</span>
                                            <span>{item}</span>
                                        </li>
                                ))}
                            </ul>
                            {exp.technologies.length > 0 && (
                                    <div class="flex flex-wrap gap-1.5">
                                        {exp.technologies.map((tech) => (
                                                <span class="px-2 py-0.5 text-xs border border-gray-700 text-gray-400 hover:border-cyan-400/40 hover:text-cyan-400 transition-colors">
                    {tech}
                  </span>
                                        ))}
                                    </div>
                            )}
                        </div>
                    </div>
            ))}
        </div>
    </div>
</section>
