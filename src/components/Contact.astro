---
import profile from '../data/profile.json';
const [emailUser, emailDomain] = profile.email.split('@');
---

<section id="contact" class="py-24 border-t border-gray-800">
    <div class="max-w-5xl mx-auto px-6">
        <div class="mb-12">
            <h2 class="text-lg font-bold text-gray-100 mb-3">
                <span class="text-cyan-400">// </span>Contact
            </h2>
            <div class="h-px bg-gray-800"></div>
        </div>

        <p class="text-sm text-gray-500 mb-8 max-w-md">
            Une question ou un projet ? Je réponds généralement sous 24h.
        </p>

        <div class="flex flex-col sm:flex-row gap-3">

            <a
                    href={profile.appointment}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-3 px-5 py-3 bg-cyan-400 text-gray-950 text-sm font-semibold hover:bg-cyan-300 transition-colors"
            >
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2"
                     stroke="currentColor" class="w-4 h-4">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5"/>
                </svg>
                Prendre rendez-vous
            </a>

            <a
                    id="contact-link"
                    href="#contact"
                    class="inline-flex items-center gap-3 px-5 py-3 border border-gray-700 text-gray-400 text-sm hover:border-cyan-400/50 hover:text-cyan-400 transition-all"
            >
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2"
                     stroke="currentColor" class="w-4 h-4">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"/>
                </svg>
                <span id="contact-email-text">job [at] jEst-ceeremielibeau [point] fr</span>
            </a>

            <script is:inline define:vars={{u: emailUser, d: emailDomain}}>
                const a = document.getElementById('contact-link');
                const span = document.getElementById('contact-email-text');
                const email = `${u}@${d}`;
                a.href = `mailto:${email}`;
                span.textContent = email;
            </script>

            {profile.linkedin && (
                    <a
                            href={profile.linkedin}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="inline-flex items-center gap-3 px-5 py-3 border border-gray-700 text-gray-400 text-sm hover:border-cyan-400/50 hover:text-cyan-400 transition-all"
                    >
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4">
                            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                        </svg>
                        LinkedIn
                    </a>
            )}

            {profile.github && (
                    <a
                            href={profile.github}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="inline-flex items-center gap-3 px-5 py-3 border border-gray-700 text-gray-400 text-sm hover:border-cyan-400/50 hover:text-cyan-400 transition-all"
                    >
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4">
                            <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
                        </svg>
                        GitHub
                    </a>
            )}
        </div>
    </div>
</section>
